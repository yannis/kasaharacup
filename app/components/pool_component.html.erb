<%= helpers.turbo_frame_tag dom_id_for_pool do %>
  <% if admin %>
    <%= helpers.turbo_stream_from category, :competition_tree %>
  <% end %>

  <div id="<%= dom_id_for_pool %>" class="pool-card">
    <h3 class="pool-card__title">Pool <%= pool_number %> (total Dan: <%= pool&.total_dan %>)</h3>

    <% if helpers.flash[:alert].present? %>
      <p class="pool-card__alert" role="alert"><%= helpers.flash[:alert] %></p>
    <% end %>

    <table class="pool-standings">
      <thead>
        <tr>
          <th>Kenshi</th>
          <th>Grade</th>
          <th>Club</th>
          <th>Age</th>
          <th>Pool</th>
          <th>Pos</th>
          <th>W</th>
          <th>L</th>
          <th>H</th>
          <th>Pts+</th>
          <th>Pts−</th>
          <th>Suggested</th>
          <th>Rank</th>
          <% if admin %><th></th><% end %>
        </tr>
      </thead>
      <tbody>
        <% standings_rows.each_with_index do |row, index| %>
          <% participation = row.participation # rubocop:disable Lint/UselessAssignment %>
          <% kenshi = participation.kenshi # rubocop:disable Lint/UselessAssignment %>
          <tr>
            <td>
              <% if kenshi %>
                <%= helpers.link_to participation.full_name, helpers.admin_kenshi_path(kenshi) %>
              <% else %>
                <%= participation.full_name %>
              <% end %>
            </td>
            <td><%= participation.grade %></td>
            <td><%= participation.club %></td>
            <td><%= kenshi&.age_at_cup %></td>
            <td>
              <% if admin %>
                <%= helpers.best_in_place participation, :pool_number, as: :input,
                      url: [:admin, participation], class: "best_in_place_short" %>
              <% else %>
                <%= participation.pool_number %>
              <% end %>
            </td>
            <td>
              <% if admin %>
                <%= helpers.best_in_place participation, :pool_position, as: :input,
                      url: [:admin, participation], class: "best_in_place_short" %>
              <% else %>
                <%= participation.pool_position %>
              <% end %>
            </td>
            <td><%= row.wins %></td>
            <td><%= row.losses %></td>
            <td><%= row.hikiwake %></td>
            <td><%= row.points_scored %></td>
            <td><%= row.points_conceded %></td>
            <% tied_with_next = standings_rows[index + 1]&.suggested_rank == row.suggested_rank %>
            <% tied_with_prev = index > 0 && standings_rows[index - 1]&.suggested_rank == row.suggested_rank %>
            <td class="pool-standings__rank"><%= row.suggested_rank %><%= "=" if tied_with_next || tied_with_prev %></td>
            <td>
              <% if admin %>
                <%= helpers.best_in_place participation, :pool_rank, as: :input,
                      url: [:admin, participation], class: "best_in_place_short" %>
              <% else %>
                <%= participation.pool_rank %>
              <% end %>
            </td>
            <% if admin %>
              <td class="pool-standings__actions">
                <%= helpers.link_to "Edit", helpers.edit_admin_participation_path(participation), data: {turbo_frame: "_top"} %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if pool_fights.empty? %>
      <p class="pool-card__empty">No pool fights yet.</p>
      <%= helpers.button_to "Generate pool fights",
            helpers.generate_pool_fights_admin_individual_category_path(category),
            method: :post,
            class: "pool-add-tiebreaker__submit",
            data: {confirm: "Generate the cyclic match list for this pool?"} %>
    <% else %>
      <ol class="pool-matches">
        <% cyclic_fights.each do |fight| %>
          <%= helpers.render "admin/pool_fights/match", category: category, fight: fight,
                point_codes: point_codes, admin: admin %>
        <% end %>
        <% tiebreaker_fights.each do |fight| %>
          <%= helpers.render "admin/pool_fights/match", category: category, fight: fight,
                point_codes: point_codes, admin: admin %>
        <% end %>
      </ol>

      <% if admin %>
        <%= helpers.form_with url: helpers.admin_individual_category_pool_fights_path(category),
              method: :post, class: "pool-add-tiebreaker" do |f| %>
          <%= f.hidden_field "pool_fight[pool_number]", value: pool_number %>
          <%= f.select "pool_fight[fighter_1_id]",
                participations.map { |p| [p.full_name, p.kenshi_id] } %>
          <span>vs</span>
          <%= f.select "pool_fight[fighter_2_id]",
                participations.map { |p| [p.full_name, p.kenshi_id] } %>
          <%= f.submit "Add tiebreaker", class: "pool-add-tiebreaker__submit" %>
        <% end %>

        <%= helpers.button_to "Reset this pool's fights",
              helpers.reset_pool_fights_admin_individual_category_path(category),
              method: :post,
              params: {pool_number: pool_number},
              class: "pool-card__reset",
              form: {class: "pool-card__reset-form"},
              data: {confirm: "This deletes every fight and tiebreaker for pool #{pool_number}. Continue?"} %>
      <% end %>
    <% end %>
  </div>
<% end %>
