<%= render(BannerComponent.new) do %>
  <% if Time.current > @cup.deadline %>
    <%= t(".deadline_passed", deadline: I18n.l(@cup.deadline, format: :long)) %>
  <% elsif @cup.not_yet_registerable? %>
    <%= t(".registrations_opening_soon", deadline: I18n.l(@cup.deadline, format: :long)) %>
  <% elsif @cup.registerable? %>
    <%= t(".deadline", deadline: I18n.l(@cup.deadline, format: :long)) %>
  <% end %>
<% end %>
<div class="max-w-7xl mx-auto py-3 px-3 sm:px-6 lg:px-8">
  <%= render(HeroComponent.new(cup: @cup, current_user: current_user)) %>
  <% if @cup.description.present? %>
    <div class="text-4xl font-extrabold tracking-tight text-slate-900 text-center py-10 md:text-7xl">
      <%= md_to_html(@cup.description) %>
    </div>
  <% end %>
  <div class="<%= @cup.registerable? ? "lg:grid lg:grid-cols-3 lg:gap-12" : "max-w-3xl mx-auto" %>">
    <div class="mt-6 prose prose-red-900 prose-lg text-gray-900 lg:col-span-2" id="program">
      <% if @headlines.any? %>
        <div class="mt-4">
          <%= render "headline", headline: @headlines.first, cup: @cup %>
        </div>
      <% end %>
      <div class="text-green-600 lg:col-span-2 bg-white shadow-xs sm:rounded-lg mt-2 p-2 text-center font-bold">
        <%= t(".public") %>
      </div>
      <% if @grouped_events.any? %>
        <% if @cup.start_on > Date.today.end_of_day - 3.days %>
          <h2 class="mt-10">
            <%= t(".program.title") %>
          </h2>
          <div class="space-y-8 not-prose">
            <% @grouped_events.each do |date, events| %>
              <div>
                <h3 class="text-sm font-bold uppercase tracking-wider text-red-900 border-b border-red-200 pb-1 mb-1">
                  <%= l date, format: :short %>
                </h3>
                <table class="w-full text-base [&_th]:border-0 [&_td]:border-0">
                  <tbody>
                    <% events.each do |event| %>
                      <tr>
                        <th class="whitespace-nowrap align-text-top text-right text-gray-400 tabular-nums font-normal py-0.5 pr-3 w-1">
                          <%= event.start_on.to_fs(:time_only) %>
                        </th>
                        <td class="py-0.5">
                          <%= md_to_html_inline(event.name) %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% end %>
          </div>
          <% if @cup.individual_categories.any? || @cup.team_categories.any? %>
            <div id="categories" class="not-prose mt-10">
              <h2 class="text-2xl font-bold text-gray-900 mb-4">
                <%= t(".categories.title") %>
              </h2>
              <table class="w-full text-base [&_th]:border-0 [&_td]:border-0">
                <tbody>
                  <% @cup.individual_categories.order(:name).each do |c| %>
                    <tr>
                      <th class="whitespace-nowrap align-text-top text-right font-semibold py-1 pr-3 w-1">
                        <%= c.name %>
                      </th>
                      <td class="text-gray-500 py-1">
                        <% if c.description.present? %>
                          <%= c.description %>
                        <% elsif c.min_age %>
                          <%= t("categories.from") %> <%= c.min_age %> <%= t("categories.yo") %>
                        <% elsif c.max_age %>
                          <%= t("categories.to") %> <%= c.max_age %> <%= t("categories.yo") %>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                  <% @cup.team_categories.each do |c| %>
                    <tr>
                      <th class="whitespace-nowrap align-text-top text-right font-semibold py-1 pr-3 w-1">
                        <%= c.name.capitalize %>
                      </th>
                      <td class="text-gray-500 py-1">
                        <%= c.description.to_s %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>
          <div id="shinpans" class="prose prose-red-900 prose-lg text-gray-900">
            <h2 class="mt-10">
              <%= t(".shinpans.title") %>
            </h2>
            <p>
              <%= t(".shinpans.info") %>
            </p>
            <% if @shinpans.any? %>
              <h3 class="mt-10">
                <%= t(".shinpans.invited.title") %>
              </h3>
              <table class="w-full text-base not-prose [&_th]:border-0 [&_td]:border-0">
                <tbody>
                  <% @shinpans.each.with_index do |shinpan, index| %>
                    <tr>
                      <td class="text-right text-gray-400 tabular-nums py-0.5 pr-2 w-1">
                        <%= index + 1 %>.
                      </td>
                      <td class="text-right py-0.5 pr-1 whitespace-nowrap">
                        <%= shinpan.female ? User.human_attribute_name(:ms) : User.human_attribute_name(:mr) %>
                      </td>
                      <th class="lg:whitespace-nowrap text-left font-semibold py-0.5 pr-2">
                        <%= shinpan.full_name %>
                      </th>
                      <td class="text-left text-gray-500 italic py-0.5 pr-2">
                        <%= shinpan.grade %>
                      </td>
                      <td class="text-right text-gray-500 py-0.5">
                        <%= shinpan.club.name %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            <% end %>
          </div>
          <% if @cup.products.any? %>
            <div id="fees" class="not-prose mt-10">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">
                <%= t(".fees.title") %>
              </h2>
              <div class="divide-y divide-gray-100">
                <% @cup.products.order(:position).each do |product| %>
                  <div class="flex items-baseline justify-between py-2">
                    <div>
                      <span class="font-semibold text-gray-900"><%= product.name %></span>
                      <% if product.description.present? %>
                        <span class="text-gray-500 text-sm ml-1">(<%= product.description %>)</span>
                      <% end %>
                      <% if product.still_available? %>
                        <% if product.remaining_spots %>
                          <span class="text-brand italic text-sm ml-1">(<%= t(".spots_left", count: product.remaining_spots) %>)</span>
                        <% end %>
                      <% else %>
                        <span class="text-brand italic text-sm ml-1">(<%= t(".products.not_available") %>)</span>
                      <% end %>
                    </div>
                    <span class="font-semibold text-gray-900 tabular-nums whitespace-nowrap ml-4"><%= t(".fee", fee_chf: product.fee_chf) %></span>
                  </div>
                <% end %>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mt-8 mb-3"><%= t(".fees.payment_title") %></h3>
              <div class="grid gap-4 sm:grid-cols-2">
                <div class="relative border-2 border-red-800 rounded-lg p-4 text-sm">
                  <span class="absolute -top-2.5 left-3 bg-red-800 text-white text-xs font-bold px-2 py-0.5 rounded-full"><%= t(".fees.prepayment_recommended") %></span>
                  <p class="font-bold text-gray-900 mt-1"><%= t(".fees.prepayment") %></p>
                  <p class="text-gray-500 text-xs mb-3"><%= t(".fees.prepayment_deadline", deadline: l(@cup.start_on - 4.days, format: :long)) %></p>
                  <dl class="space-y-1 text-gray-700">
                    <div class="flex gap-2">
                      <dt class="text-gray-500 shrink-0">IBAN</dt>
                      <dd class="font-mono text-xs self-center"><%= ENV.fetch("BANK_IBAN") %></dd>
                    </div>
                    <div class="flex gap-2">
                      <dt class="text-gray-500 shrink-0">BIC/SWIFT</dt>
                      <dd class="font-mono text-xs self-center"><%= ENV.fetch("BANK_BIC") %></dd>
                    </div>
                    <div class="flex gap-2">
                      <dt class="text-gray-500 shrink-0"><%= t("activerecord.attributes.kenshi.name") %></dt>
                      <dd><%= ENV.fetch("BANK_ACCOUNT_HOLDER") %></dd>
                    </div>
                  </dl>
                  <div class="mt-3 bg-red-50 border border-red-200 rounded p-2">
                    <p class="text-xs text-gray-500"><%= t(".fees.prepayment_reference_label") %></p>
                    <p class="font-bold text-red-900 text-sm"><%= t(".fees.prepayment_reference") %></p>
                  </div>
                </div>
                <div class="border border-gray-200 rounded-lg p-4 text-sm">
                  <p class="font-bold text-gray-900 mt-1"><%= t(".fees.on_the_spot") %></p>
                  <p class="text-gray-500 mt-2"><%= t(".fees.description") %></p>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
      <div id="venue" class="prose prose-red-900 prose-lg text-gray-900 lg:col-span-2">
        <h2 class="mt-10">
          <%= t(".venue.title") %>
        </h2>
        <p>
          <%= t(".venue.a_html", stade_du_bout_du_monde: link_to("Centre sportif du Bout-du-Monde", "http://www.ville-geneve.ch/plan-ville/sports/centre-sportif-bout-monde/")) %>
        </p>
        <h3>
          <%= t(".venue.address.title") %>
        </h3>
        <%= md_to_html(t(".venue.address.content")) %>
      </div>
      <div id="accomodation" class="prose prose-red-900 prose-lg text-gray-900 lg:col-span-2">
        <h2 class="mt-10">
          <%= t ".accomodation.title" %>
        </h2>
        <p>
          <%= t ".accomodation.hotels_html" %>
        </p>
      </div>
    </div>
    <% if @cup.registerable? %>
      <div class="mt-10">
        <%= render "current_user_resume", cup: @cup %>
      </div>
    <% end %>
  </div>
</div>
